pipeline {
    agent any

    stages {
        stage('clone from SCM') {
            steps {
                echo 'cloning project code'
                git branch: 'main', url: 'https://github.com/kavana-nataraj/mindcircuit13.git'
            }
        }
      stage('build artifacts') {
            steps {
                echo 'generating artifacts using maven build tool'
                 sh '''mvn clean install'''
            }
        }
       stage('deploy to tomcat') {
            steps {
                echo 'deploying artefact to app server'
                 deploy adapters: [tomcat9(credentialsId: 'tomcat', path: '', url: 'http://ec2-35-173-244-127.compute-1.amazonaws.com:8081/')], contextPath: 'fb-app', war: '**/*.war'
            }
        }
    }
}
